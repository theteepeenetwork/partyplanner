# Copy to .env for local/agent development:
#   cp env.example .env
#
# Cloud agents and browser QA should use the "cloud" environment (no Kint toolbar).

CI_ENVIRONMENT = cloud

# Dev server URL (use 127.0.0.1 — bind spark with: php spark serve --host 127.0.0.1 --port 8888)
app.baseURL = http://127.0.0.1:8888/

# Optional: force toolbar off even in development
# DISABLE_DEBUG_TOOLBAR = true

# database.app.hostname = 127.0.0.1
# database.app.database = event_marketplace
# database.app.username = root
# database.app.password =
