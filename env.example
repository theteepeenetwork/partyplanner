# Copy to .env for local/agent development:
#   cp env.example .env
#
# Cloud agents and browser QA should use the "cloud" environment (no Kint toolbar).

CI_ENVIRONMENT = cloud
app.baseURL = 'http://partyplanner.home/'

# Optional: force toolbar off even in development
# DISABLE_DEBUG_TOOLBAR = true

# Homepage hero subtitle A/B variant: a, b, or c (see app/Config/Branding.php)
# HERO_SUBTITLE_VARIANT = a

# White-label vendor sites: hosts like <subdomain>.<tenant.baseDomain> serve a
# vendor's branded storefront (see docs/whitelabel-dev-setup.md). Defaults to
# partysmith.co.uk (production). For local dev use *.partyplanner.test.
# tenant.baseDomain = partyplanner.test

# Database — the app runs in Docker; the DB host is the `mariadb` service.
# Set the password to match your mariadb container (it is NOT blank locally).
database.default.hostname = mariadb
database.default.database = event_marketplace
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.port = 3306

database.app.hostname = mariadb
database.app.database = event_marketplace
database.app.username = root
database.app.password =
database.app.DBDriver = MySQLi
database.app.port = 3306
