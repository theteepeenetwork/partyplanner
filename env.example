# Copy this file to `.env` in the project root (same folder as `spark`).
# Restart PHP / Apache after editing. Keys must match CodeIgniter names below.
#
# Access denied for user '...'@'localhost' (using password: YES)
# means username/password (or host) do not match MySQL. Fix in MySQL first, then here.
# Test: mysql -h localhost -u YOUR_USER -p
#
# On Windows, if localhost behaves oddly, try: database.default.hostname = 127.0.0.1
#
# Empty database.default.password is only valid if that MySQL user has no password.

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = event_marketplace
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.port = 3306
